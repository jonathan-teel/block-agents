DATABASE_URL=postgres://postgres:postgres@localhost:5432/blockagents?sslmode=disable
PORT=8080
CHAIN_ID=blockagents-devnet-1
NODE_ID=blockagentsd-1
P2P_LISTEN_ADDR=http://127.0.0.1:8080
SEED_PEERS=http://127.0.0.1:8081,http://127.0.0.1:8082
VALIDATOR_ADDRESS=validator-1
VALIDATOR_PRIVATE_KEY=<ed25519-private-key-hex>
CONSENSUS_ROUND_TIMEOUT_SECONDS=10
SYNC_LOOKAHEAD_BLOCKS=6
ROLE_SELECTION_POLICY=balance_reputation
MINER_VOTE_POLICY=reputation_weighted
REORG_POLICY=best_certified
ALLOW_EARLY_DEBATE_ADVANCE=true
MIN_EVALUATIONS_PER_PROPOSAL=1
MIN_VOTES_PER_ROUND=1
VALIDATOR_SLASH_FRACTION=0.1
VALIDATOR_SLASH_REPUTATION_PENALTY=0.2
GENESIS_FILE=configs/devnet.genesis.json
BLOCK_INTERVAL_SECONDS=5
MAX_TRANSACTIONS_PER_BLOCK=250
MAX_EFFECTIVE_WEIGHT=100
CREATE_EMPTY_BLOCKS=true
ENABLE_FAUCET=true
FAUCET_GRANT_AMOUNT=1000
DEFAULT_AGENT_REPUTATION=0.5
